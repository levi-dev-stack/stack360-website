{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "!node_modules",
      "!.next",
      "!out",
      "!dist",
      "!build",
      "!coverage",
      "!next-env.d.ts",
      "!.vscode",
      "!.husky"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedPrivateClassMembers": "error",
        "noConstAssign": "error",
        "noEmptyPattern": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noApproximativeNumericConstant": "warn",
        "noUnknownAtRules": "off",
        "noEmptyBlockStatements": "warn"
      },
      "style": {
        "useBlockStatements": "error",
        "useConsistentArrayType": "error",
        "useShorthandAssign": "error",
        "noNegationElse": "error",
        "noUselessElse": "error",
        "noYodaExpression": "warn"
      },
      "performance": {
        "noDelete": "warn",
        "noAccumulatingSpread": "warn",
        "noAwaitInLoops": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5",
      "arrowParentheses": "always"
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": false
    }
  }
}
